# ── Core secrets ────────────────────────────────────────────────────────────────
SECRET_KEY=YOUR_SHARED_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256

# ── Postgres / TimescaleDB ──────────────────────────────────────────────────────
POSTGRES_USER=smartsec
POSTGRES_PASSWORD=smartsecpass
POSTGRES_DB=smartsec
DATABASE_URL=postgresql+asyncpg://smartsec:smartsecpass@db:5432/smartsec

# ── Redis (cache + Celery broker) ───────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MinIO object storage ────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=sensor-media

# ── SMTP for alert e-mail (example uses SendGrid) ───────────────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_USERNAME=apikey
EMAIL_PASSWORD=SG.xxxxx
EMAIL_FROM=alerts@smartsecurity.solutions

# ── Traefik dashboard basic-auth ────────────────────────────────────────────────
TRAEFIK_DASHBOARD_USER=admin
TRAEFIK_DASHBOARD_PASSWORD_HASH=$apr1$M1J8j...   # htpasswd -nb admin strongpass

# ── Misc settings ──────────────────────────────────────────────────────────────
LOG_LEVEL=info
ALLOW_ORIGINS=https://client.smartsecurity.solutions,https://admin.smartsecurity.solutions
