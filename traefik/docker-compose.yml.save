
services:
  traefik:
    image: traefik:v2.9
    restart: unless-stopped
    command:
      - --configFile=/etc/traefik/traefik.yml
    ports:
      - "80:80"
      - "443:443"
    volumes:
      - ./traefik.yml:/etc/traefik/traefik.yml:ro
      - ./acme.json:/acme.json
      - /var/run/docker.sock:/var/run/docker.sock:ro
    labels:
      - "traefik.enable=true"

  ############################################################
  # Admin Dashboard backend ─ PHP-FPM + Nginx (upload.php)
  ############################################################

  php-fpm:
    build:
      context: ./backend
      dockerfile: Dockerfile
    restart: unless-stopped
    volumes:
      - ./backend:/var/www/html           # your PHP code goes here
    depends_on:
      - db
    labels:
      - "traefik.enable=false"

  nginx:
    image: nginx:1.27-alpine
    restart: unless-stopped
    volumes:
      - ./backend:/var/www/html:ro        # serve PHP app read-only
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf:ro
    depends_on:
      - php-fpm
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.upload.rule=Host(`cloud.smartsecurity.solutions`) && Path(`/upload.php`)"
      - "traefik.http.routers.upload.entrypoints=websecure"
      - "traefik.http.routers.upload.tls.certresolver=le"
      - "traefik.http.services.upload.loadbalancer.server.port=80"
# ──────────────────────────────────────────────────────────────
# Admin Dashboard (Vue static files) served by its own Nginx
# ──────────────────────────────────────────────────────────────

  dashboard:
    build:
      context: ../dashboard/admin-dashboard
      dockerfile: Dockerfile
    restart: unless-stopped
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.dashboard.rule=Host(`admin.smartsecurity.solutions`)"
      - "traefik.http.routers.dashboard.entrypoints=websecure"
      - "traefik.http.routers.dashboard.tls.certresolver=le"
      - "traefik.http.services.dashboard.loadbalancer.server.port=80"

  api:
    build:
      context: ../services/api
      dockerfile: Dockerfile
    restart: unless-stopped
    environment:
      DATABASE_URL: "postgresql://ssc:ChangeMeToAStrongPass!@db:5432/sensordb"
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.api.rule=Host(`cloud.smartsecurity.solutions`) && PathPrefix(`/api`)"
      - "traefik.http.routers.api.entrypoints=websecure"
      - "traefik.http.routers.api.tls.certresolver=le"
      - "traefik.http.services.api.loadbalancer.server.port=5000"
      - "traefik.http.middlewares.api-strip-prefix.stripprefix.prefixes=/api"
      - "traefik.http.routers.api.middlewares=api-strip-prefix"
      # ───────────────────────────────────────────────
      # New: mirror the same API under the admin host
      # ───────────────────────────────────────────────
      - "traefik.http.routers.api-admin.rule=Host(`admin.smartsecurity.solutions`) && PathPrefix(`/api`)"
      - "traefik.http.routers.api-admin.entrypoints=websecure"
      - "traefik.http.routers.api-admin.tls.certresolver=le"
      - "traefik.http.services.api.loadbalancer.server.port=5000"
      - "traefik.http.routers.api-admin.middlewares=api-strip-prefix"


  db:
    image: postgres:15-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: ssc
      POSTGRES_PASSWORD: ChangeMeToAStrongPass!
      POSTGRES_DB: sensordb
    volumes:
      - db_data:/var/lib/postgresql/data

  ws:
    build: ../services/ws
    restart: unless-stopped
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.ws.rule=Host(`cloud.smartsecurity.solutions`) && PathPrefix(`/ws`)"
      - "traefik.http.routers.ws.entrypoints=websecure"
      - "traefik.http.routers.ws.tls.certresolver=le"
      - "traefik.http.services.ws.loadbalancer.server.port=8000"
      # mirror under admin.smartsecurity.solutions
      - "traefik.http.routers.ws-admin.rule=Host(`admin.smartsecurity.solutions`) && PathPrefix(`/ws`)"
      - "traefik.http.routers.ws-admin.entrypoints=websecure"
      - "traefik.http.routers.ws-admin.tls.certresolver=le"
      - "traefik.http.services.ws.loadbalancer.server.port=8000"

  mqtt:
    image: eclipse-mosquitto:2.0
    restart: unless-stopped
    ports:
      - "1883:1883"
    volumes:
      - mosquitto_data:/mosquitto/data
      - mosquitto_log:/mosquitto/log
      - ./mosquitto/config/mosquitto.conf:/mosquitto/config/mosquitto.conf:ro
    labels:
      - "traefik.enable=false"

  bridge:
    build: ../services/bridge
    restart: unless-stopped
    environment:
      DATABASE_URL: "postgresql://ssc:ChangeMeToAStrongPass!@db:5432/sensordb"
      MQTT_BROKER: mqtt
      MQTT_PORT: "1883"
      MQTT_TOPIC: sensors/+/data
    labels:
      - "traefik.enable=false"

volumes:
  db_data:
  mosquitto_data:
  mosquitto_log:
